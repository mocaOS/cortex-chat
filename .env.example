# --- Backend -----------------------------------------------------------------
# URL of your Cortex backend. Server-only — the browser never calls the backend
# directly (all calls go through this app's /api/* proxy).

CORTEX_API_URL=http://localhost:8000

# Admin-tier Cortex backend key. Used server-side to mint per-group / per-user
# keys and to list collections in the admin UI. Never exposed to the browser.

BACKEND_ADMIN_API_KEY=moca_admin_your-admin-key-here

# --- Superadmin bootstrap ----------------------------------------------------
# On every server start, a users row with role='superadmin' is upserted from
# these values (password re-hashed each boot, so rotating is trivial).

SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me

# --- Encryption --------------------------------------------------------------
# 32 random bytes, base64 encoded. Generate with:
#   openssl rand -base64 32
# Used to encrypt Cortex backend API keys at rest in SQLite.

APP_ENCRYPTION_KEY=

# --- Storage (optional override) --------------------------------------------
# Branding (accent color, logo, page title, description, default language) is
# managed by the superadmin at /admin/settings and stored in SQLite — no env
# vars for branding.

# DATABASE_PATH=./data/cortex-chat.db

# --- GlitchTip error tracking (optional) --------------------------------------
# Error reporting to https://glitchtip.cortex.eco is built in (production
# builds only; the DSN is a submit-only public identifier baked into the app).
# No env vars are required for events to flow.
#
# SENTRY_AUTH_TOKEN — BUILD-time only. Enables source map upload so stack
# traces show the original TypeScript. In Coolify, add it as a build variable
# (docker-compose passes it as a build arg); locally:
#   SENTRY_AUTH_TOKEN=<token> npm run build
# Tokens: https://glitchtip.cortex.eco → profile → auth tokens
# (needs project:releases + project:write).

# SENTRY_AUTH_TOKEN=

# Runtime knobs (all optional):
# SENTRY_ENVIRONMENT=production   # tag events per deployment/tenant
# SENTRY_DSN=                     # override the baked-in DSN (server-side)
# SENTRY_DISABLED=1               # kill switch — no events at all

# --- Email / SMTP (optional) -------------------------------------------------
# Enables the password-reset flow. Leave SMTP_HOST unset to keep email off
# entirely (the "Forgot password?" link and admin "Send reset email" button
# are hidden). When SMTP_HOST is set, SMTP_FROM and APP_BASE_URL are required.
#
# Local testing with Mailpit: SMTP is on port 1025 (NOT 8025 — that's Mailpit's
# web UI where you read the delivered mail).
#   SMTP_HOST=localhost
#   SMTP_PORT=1025
#   SMTP_FROM="Cortex Chat <no-reply@example.com>"
#   APP_BASE_URL=http://localhost:3000

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=            # optional (omit for Mailpit — no auth)
# SMTP_PASS=            # optional (omit for Mailpit)
# SMTP_SECURE=false     # true ⇒ implicit TLS (port 465); false ⇒ STARTTLS (587)
# SMTP_FROM=
# APP_BASE_URL=
